# FlowBook backend configuration

# HTTP server port
PORT=4000

# Prisma datasource (SQLite file, resolved relative to prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# Timezone used for budget periods, reminders and reports
TZ=Asia/Bangkok

# Background scheduler (auto-log + daily reminders). Set to "false" to disable.
ENABLE_SCHEDULER=true

# LINE Messaging API (optional — leave blank to run the server without LINE).
# When both are set, the /line/webhook endpoint verifies signatures and can reply/push.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
