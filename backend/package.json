{
  "name": "flowbook-backend",
  "version": "0.1.0",
  "private": true,
  "description": "FlowBook backend — Thai income/expense engine (ป้านวล feature parity) + POS revenue ingestion + real-time P&L, with an optional LINE webhook.",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset --accept-data-loss && tsx prisma/seed.ts",
    "test:parser": "tsx src/lib/parser.test.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.5.0",
    "@prisma/client": "^6.7.0",
    "dayjs": "^1.11.13",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
